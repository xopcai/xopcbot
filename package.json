{
  "name": "@xopcai/xopcbot",
  "version": "0.2.2",
  "description": "Ultra-Lightweight Personal AI Assistant - Node.js + TypeScript",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js",
      "default": "./dist/src/index.js"
    },
    "./extension-sdk": {
      "types": "./dist/src/extensions/sdk/index.d.ts",
      "import": "./dist/src/extensions/sdk/index.js",
      "default": "./dist/src/extensions/sdk/index.js"
    },
    "./extension-sdk/*": "./dist/src/extensions/sdk/*",
    "./*": "./dist/src/*"
  },
  "bin": {
    "xopcbot": "./dist/src/cli/index.js"
  },
  "files": [
    "dist",
    "skills"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "generate:bundled-channels": "node scripts/generate-bundled-channel-plugins.mjs",
    "build:node": "node scripts/tsdown-build.mjs",
    "build": "pnpm run generate:bundled-channels && pnpm run build:node && pnpm run build:web",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:web": "pnpm -C web run build",
    "dev:web": "pnpm -C web run dev",
    "dev": "tsx src/cli/index.ts",
    "start": "node dist/src/cli/index.js",
    "test": "vitest run src extensions/telegram/src",
    "test:skills": "vitest run src/agent/skills/__tests__",
    "test:skills:regression": "./scripts/test-skills.sh",
    "test:skills:all": "npm run test:skills && npm run test:skills:regression",
    "skills:test": "tsx src/cli/index.ts skills test",
    "skills:validate": "tsx src/cli/index.ts skills test validate",
    "skills:security": "tsx src/cli/index.ts skills test security",
    "lint": "eslint",
    "prepublishOnly": "npm test && npm run test:skills:all && npm run build",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs",
    "electron:dev": "cross-env ELECTRON_ENTRY=out/main/index.js electron-vite dev",
    "electron:vite:build": "cross-env ELECTRON_ENTRY=out/main/index.js electron-vite build",
    "electron:package": "node scripts/electron-builder.mjs",
    "electron:build": "pnpm run electron:vite:build && pnpm run electron:package",
    "electron:preview": "cross-env ELECTRON_ENTRY=out/main/index.js electron-vite preview"
  },
  "keywords": [
    "ai",
    "agent",
    "chatbot",
    "personal-assistant",
    "llm",
    "openai",
    "claude",
    "telegram",
    "automation"
  ],
  "author": "Xu Micjoyce <micjoyce@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xopcai/xopcbot.git"
  },
  "bugs": {
    "url": "https://github.com/xopcai/xopcbot/issues"
  },
  "homepage": "https://github.com/xopcai/xopcbot#readme",
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.16.1",
    "@grammyjs/runner": "^2.0.3",
    "@grammyjs/types": "^3.25.0",
    "@hono/node-server": "^1.19.9",
    "@inquirer/prompts": "^8.2.1",
    "@mariozechner/pi-agent-core": "^0.64.0",
    "@mariozechner/pi-ai": "^0.64.0",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.48",
    "@vscode/ripgrep": "^1.17.1",
    "adm-zip": "^0.5.16",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "cron-parser": "^5.5.0",
    "dotenv": "^17.3.1",
    "glob": "^13.0.3",
    "grammy": "^1.40.0",
    "hono": "^4.11.9",
    "jiti": "^2.6.1",
    "js-yaml": "^4.1.1",
    "jsdom": "^29.0.1",
    "node-cron": "^4.2.1",
    "node-edge-tts": "^1.2.10",
    "openai": "^6.25.0",
    "partial-json": "^0.1.7",
    "pino": "^10.3.1",
    "qrcode-terminal": "^0.12.0",
    "silk-wasm": "^3.7.1",
    "uuid": "^13.0.0",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.17",
    "@types/adm-zip": "^0.5.8",
    "@types/js-yaml": "^4.0.9",
    "@types/jsdom": "^28.0.1",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.2.3",
    "@types/node-cron": "^3.0.11",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.0.0",
    "markdown-it": "^14.1.1",
    "pino-pretty": "^13.1.3",
    "tailwindcss": "^4.1.17",
    "tsdown": "0.21.7",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vite": "^7.3.1",
    "vitepress": "^1.6.4",
    "vitest": "4.0.18",
    "vue": "^3.5.28"
  }
}
