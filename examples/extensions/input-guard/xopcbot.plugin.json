{
  "id": "input-guard",
  "name": "Input Guard",
  "description": "Example extension demonstrating input hook - content moderation and command interception",
  "version": "1.0.0",
  "kind": "utility",
  "main": "index.ts",
  "configSchema": {
    "type": "object",
    "properties": {
      "blockedWords": {
        "type": "array",
        "items": { "type": "string" },
        "default": ["spam", "scam"],
        "description": "Words to block in messages"
      },
      "enableQuickCommands": {
        "type": "boolean",
        "default": true,
        "description": "Enable !command shortcuts"
      },
      "logAllInput": {
        "type": "boolean",
        "default": false,
        "description": "Log all input for debugging"
      }
    }
  }
}
