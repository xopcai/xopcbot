{
  "id": "custom-provider",
  "name": "Custom Provider Example",
  "description": "Demonstrates Phase 4 provider registration with custom models",
  "version": "1.0.0",
  "kind": "utility",
  "main": "index.ts",
  "configSchema": {
    "type": "object",
    "properties": {
      "proxyUrl": {
        "type": "string",
        "default": "https://api.example.com",
        "description": "Custom API proxy URL"
      },
      "apiKey": {
        "type": "string",
        "description": "API key for the proxy"
      }
    }
  }
}
