{
  "id": "progress-tracker",
  "name": "Progress Tracker",
  "description": "Example extension demonstrating Phase 2 enhanced tools with streaming updates and state persistence",
  "version": "1.0.0",
  "kind": "tool",
  "main": "index.ts",
  "configSchema": {
    "type": "object",
    "properties": {
      "showProgressInChat": {
        "type": "boolean",
        "default": true,
        "description": "Show progress updates in chat"
      },
      "trackHistory": {
        "type": "boolean",
        "default": true,
        "description": "Track tool execution history"
      }
    }
  }
}
