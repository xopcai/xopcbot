# xopcbot Configuration
# Copy this to .env and fill in your values

# ===========================================
# LLM Providers (choose one or more)
# ===========================================

# OpenRouter (recommended for best model selection)
OPENROUTER_API_KEY=sk-or-v1-xxx

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-api-xxx

# OpenAI (GPT-4, o1)
OPENAI_API_KEY=sk-xxx

# Google Gemini
GOOGLE_API_KEY=xxx
GEMINI_API_KEY=xxx

# Ollama (local models)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=

# vLLM Local Model
VLLM_API_BASE=http://localhost:8000/v1
VLLM_API_KEY=dummy

# DeepSeek
DEEPSEEK_API_KEY=sk-xxx

# Groq (fast inference)
GROQ_API_KEY=gsk_xxx

# xAI (Grok)
XAI_API_KEY=xai-xxx

# Qwen (阿里通义千问)
QWEN_API_KEY=sk-xxx
# or: DASHSCOPE_API_KEY=sk-xxx

# Kimi/Moonshot (月之暗面)
MOONSHOT_API_KEY=sk-xxx
# or: KIMI_API_KEY=sk-xxx

# Zhipu (智谱AI)
ZHIPU_API_KEY=sk-xxx
# or: ZHIPU_CN_API_KEY=sk-xxx

# Minimax
MINIMAX_API_KEY=sk-xxx

# AWS Bedrock
AWS_ACCESS_KEY_ID=xxx
AWS_SECRET_ACCESS_KEY=xxx

# Default Model
DEFAULT_MODEL=anthropic/claude-sonnet-4-5

# ===========================================
# Web Search
# ===========================================

# Brave Search
BRAVE_SEARCH_API_KEY=BSA-xxx

# ===========================================
# Messaging Platforms (Telegram, WhatsApp, etc.)
# ===========================================

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxx
TELEGRAM_ALLOW_FROM=["123456789", "username"]

# WhatsApp
WHATSAPP_BRIDGE_URL=ws://localhost:3001
WHATSAPP_ALLOW_FROM=["+1234567890"]

# Discord
DISCORD_BOT_TOKEN=xxx
DISCORD_ALLOW_FROM=["123456789"]

# Slack
SLACK_BOT_TOKEN=xoxb-xxx
SLACK_ALLOW_FROM=["U123456"]

# Signal
SIGNAL_CLI_PATH=/usr/bin/signal-cli
SIGNAL_ALLOW_FROM=["+1234567890"]

# ===========================================
# Server Settings
# ===========================================

HOST=0.0.0.0
PORT=18790

# ===========================================
# Workspace
# ===========================================

WORKSPACE=~/.xopcbot/workspace

# ===========================================
# Logging (optional)
# ===========================================

# Log level: trace, debug, info, warn, error
# LOG_LEVEL=info

# Enable pretty console logs (true/false)
# XOPCBOT_PRETTY_LOGS=true

# Log file path (default: ~/.xopcbot/logs/xopcbot.log)
# XOPCBOT_LOG_FILE=~/.xopcbot/logs/xopcbot.log

# Log retention days (default: 7)
# XOPCBOT_LOG_RETENTION_DAYS=7

# ===========================================
# Development
# ===========================================

# Enable debug mode
# DEBUG=true

# Node environment (development, production)
# NODE_ENV=development
